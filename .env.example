# 数据库路径（SQLite）
DATABASE_URL=sqlite:./data/comments.db?mode=rwc

# 服务监听地址
SERVER_HOST=0.0.0.0
SERVER_PORT=3080

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=change-me-to-a-random-secret-key

# 管理员密码（首次运行后可通过 CLI 修改）
ADMIN_PASSWORD=admin123

# 站点名称
SITE_NAME=Comment System

# 上传目录
UPLOAD_DIR=./data/uploads

# 允许的来源（CORS），逗号分隔
ALLOWED_ORIGINS=*

# SMTP 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# 通知推送配置（可选）
NOTIFY_WEBHOOK_URL=

# 验证码配置
CAPTCHA_ENABLED=false
CAPTCHA_TYPE=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
