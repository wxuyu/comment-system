# Artalk-rs runtime configuration.
# All keys use the ATK_<SECTION>__<KEY> prefix (double underscore separates sections).
# Only the hot-set is wired; see crates/core/src/config.rs for the full schema.

# PostgreSQL connection. Required in production (Vercel).
# For a managed Postgres (Neon/Supabase/RDS) put the full URL here:
ATK_DB__DSN=postgres://user:password@host:5432/artalk

# App key (used to sign JWTs). Generate a long random string.
ATK_APP__KEY=change-me-to-a-long-random-string

# Default site name used when a request omits site_name.
ATK_SITE__DEFAULT=Default

# Enable email/password auth.
ATK_AUTH__ENABLED=true

# Captcha type: image | recaptcha | hcaptcha | turnstile | geetest
ATK_CAPTCHA__TYPE=image

# SMTP (used for verification emails + reply notifications).
ATK_EMAIL__HOST=
ATK_EMAIL__USERNAME=
ATK_EMAIL__PASSWORD=
ATK_EMAIL__FROM=noreply@example.com
