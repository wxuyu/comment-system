# ===== BlogComment Rust (Artalk-compatible) 环境变量 =====
# 本地开发用 libSQL 文件；部署到 Vercel 用 Turso 云数据库

# Vercel + Turso 配置（生产）
TURSO_URL=libsql://your-db.turso.io
DATABASE_TOKEN=your-turso-token

# 本地文件数据库（默认，TURSO_URL 未设置时使用）
DATABASE_URL=file:./data/artalk.db

# JWT 签名密钥（务必修改为随机长字符串）
APP_KEY=change-me-please-use-a-long-random-string

# 默认站点名（首次启动自动创建）
SITE_DEFAULT=Default Site

# 登录有效期（秒）
LOGIN_TIMEOUT=259200

# 新评论是否默认待审核
PENDING_DEFAULT=false

# CORS 允许的源（前端地址），生产填前端 Vercel 域名
CORS_ORIGIN=*





# Gravatar 镜像
GRAVATAR_MIRROR=https://www.gravatar.com/avatar/