# ============================================================
# Vercel 部署环境变量模板
# 在 Vercel 项目设置 → Environment Variables 中配置这些值
# 或在 vercel link 后使用 `vercel env add <key>` 添加
# ============================================================

# --- 数据库 (Turso / libSQL) ---
DATABASE_URL=libsql://your-db.turso.io
DATABASE_TOKEN=your-turso-token

# --- 服务端口 (Vercel 自动注入 PORT，通常无需设置) ---
# PORT=3000

# --- JWT 签名密钥 (必填，生产环境请使用随机长字符串) ---
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# --- 管理员 ---
ADMIN_PASSWORD=your-secure-admin-password
SITE_NAME=My Comment System

# --- CORS (Vercel 上通常设为你的前端域名，开发可设 *) ---
ALLOWED_ORIGINS=*

# --- 验证码 (Cloudflare Turnstile，可选) ---
CAPTCHA_ENABLED=true
CAPTCHA_TYPE=turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- 邮件通知 (SMTP，可选) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# --- 缓存 / OAuth State (Upstash Redis，可选但推荐) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 文件存储 (Vercel Blob，可选) ---
BLOB_READ_WRITE_TOKEN=

# --- OAuth 社交登录 (可选，每个 provider 一组) ---
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# --- 公开 URL (用于邮件验证链接等，Vercel 会自动注入 VERCEL_PROJECT_PRODUCTION_URL) ---
# PUBLIC_URL=https://your-domain.vercel.app
